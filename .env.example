# ─────────────────────────────────────────────────────────────
# APPLICATION
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://votre-domaine.fr
NEXT_PUBLIC_APP_NAME="Gestion Commerciale"
NODE_ENV=production

# ─────────────────────────────────────────────────────────────
# BASE DE DONNÉES (PostgreSQL sur Hostinger)
# Activer SSL avec ?sslmode=require pour chiffrement en transit
# ─────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOSTINGER_IP:5432/DBNAME?sslmode=require"

# ─────────────────────────────────────────────────────────────
# AUTHENTIFICATION (Auth.js v5)
# Générer avec : openssl rand -base64 32
# ─────────────────────────────────────────────────────────────
AUTH_SECRET="GENERER_UNE_VALEUR_SECRETE_ICI"
AUTH_URL=https://votre-domaine.fr

# ─────────────────────────────────────────────────────────────
# TEMPS RÉEL (SSE interne — pas besoin de service externe)
# Clé secrète pour valider les émissions d'événements
# ─────────────────────────────────────────────────────────────
SSE_SECRET="GENERER_UNE_VALEUR_SECRETE_ICI"

# ─────────────────────────────────────────────────────────────
# STOCKAGE DOCUMENTS (Serveur Hostinger)
# Dossier pour les PDFs générés (factures, reçus, rapports)
# ─────────────────────────────────────────────────────────────
DOCUMENTS_STORAGE_PATH="/var/www/documents"
DOCUMENTS_BASE_URL=https://votre-domaine.fr/documents
DOCUMENTS_SIGN_SECRET="GENERER_UNE_VALEUR_SECRETE_ICI"

# ─────────────────────────────────────────────────────────────
# EMAIL (Resend)
# Créer un compte sur resend.com
# ─────────────────────────────────────────────────────────────
RESEND_API_KEY="re_VOTRE_CLE_API"
EMAIL_FROM="noreply@votre-domaine.fr"

# ─────────────────────────────────────────────────────────────
# MONITORING (Sentry)
# Créer un projet sur sentry.io
# ─────────────────────────────────────────────────────────────
SENTRY_DSN="https://VOTRE_DSN@sentry.io/PROJET_ID"
NEXT_PUBLIC_SENTRY_DSN="https://VOTRE_DSN@sentry.io/PROJET_ID"
SENTRY_ORG="votre-org"
SENTRY_PROJECT="gestion-commerciale"

# ─────────────────────────────────────────────────────────────
# RATE LIMITING
# Nombre de requêtes max par fenêtre de temps
# ─────────────────────────────────────────────────────────────
RATE_LIMIT_AUTH_MAX=10
RATE_LIMIT_AUTH_WINDOW=900000
RATE_LIMIT_API_MAX=100
RATE_LIMIT_API_WINDOW=60000

# ─────────────────────────────────────────────────────────────
# LOGS (Pino)
# ─────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_EXTERNAL_ENDPOINT=https://votre-service-logs.fr/ingest

# ─────────────────────────────────────────────────────────────
# PWA / SERVICE WORKER
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_ENABLE_PWA=true
